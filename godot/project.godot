; DCC — native Godot 4 client (Phase 0 scaffold). See ../GODOT_PORT.md.
config_version=5

[application]
config/name="DCC — The Infinite Descent (Godot client)"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[dotnet]
project/assembly_name="dcc"

[editor_plugins]
enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[input]
move_left={
"deadzone": 0.5,
"events": [{"type":"key","keycode":65,"physical_keycode":0,"unicode":0,"echo":false},{"type":"key","keycode":4194319,"physical_keycode":0,"unicode":0,"echo":false}]
}
move_right={
"deadzone": 0.5,
"events": [{"type":"key","keycode":68,"physical_keycode":0,"unicode":0,"echo":false},{"type":"key","keycode":4194321,"physical_keycode":0,"unicode":0,"echo":false}]
}
move_up={
"deadzone": 0.5,
"events": [{"type":"key","keycode":87,"physical_keycode":0,"unicode":0,"echo":false},{"type":"key","keycode":4194320,"physical_keycode":0,"unicode":0,"echo":false}]
}
move_down={
"deadzone": 0.5,
"events": [{"type":"key","keycode":83,"physical_keycode":0,"unicode":0,"echo":false},{"type":"key","keycode":4194322,"physical_keycode":0,"unicode":0,"echo":false}]
}

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
